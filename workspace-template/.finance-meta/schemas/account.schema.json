{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfinance.app/schemas/account.schema.json",
  "title": "Account (Accounts/accounts.csv)",
  "schema_version": 1,
  "file": "Accounts/accounts.csv",
  "domain": "accounts",
  "subtype": "registry",
  "columns": {
    "account_id": { "type": "string", "required": true },
    "display_name": { "type": "string", "required": true },
    "institution": { "type": "string", "required": true },
    "account_group": { "type": "enum", "required": true,
      "values": ["employment", "business", "credit_card", "investment", "savings", "checking", "loan"],
      "display_names": { "Everyday Banking": "checking", "Credit Cards": "credit_card", "Loans & Debt": "loan", "Savings": "savings", "Investments": "investment", "Employment": "employment", "Business": "business" } },
    "account_type": { "type": "string", "required": true },
    "status": { "type": "enum", "required": true, "values": ["draft", "active", "frozen", "closed"] },
    "account_group_id": { "type": "string", "required": true },
    "current_balance": { "type": "decimal", "required": false },
    "tax_treatment": { "type": "string", "required": false },
    "performance_tracking": { "type": "boolean", "required": false }
  }
}
